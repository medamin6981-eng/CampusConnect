<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.enspd.campusconnect.controller.ScheduleController"
      spacing="20" styleClass="content-pane">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher une séance (Cours, Salle, Enseignant)..." prefWidth="400"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Planifier Séance" styleClass="btn-primary" onAction="#handleNewSession"/>
    </HBox>

    <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCourse" text="Cours" prefWidth="150"/>
            <TableColumn fx:id="colGroup" text="Groupe" prefWidth="100"/>
            <TableColumn fx:id="colTeacher" text="Enseignant" prefWidth="200"/>
            <TableColumn fx:id="colRoom" text="Salle" prefWidth="100"/>
            <TableColumn fx:id="colStart" text="Début" prefWidth="150"/>
            <TableColumn fx:id="colEnd" text="Fin" prefWidth="150"/>
        </columns>
    </TableView>

</VBox>
