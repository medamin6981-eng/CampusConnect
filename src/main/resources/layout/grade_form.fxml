<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.enspd.campusconnect.controller.GradeFormController"
      spacing="15" prefWidth="400" alignment="CENTER"
      style="-fx-background-color: #1A1C1E; -fx-padding: 30;">

    <Text text="Nouvelle Note" style="-fx-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
    
    <GridPane vgap="10" hgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        
        <Label text="Inscription:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="0"/>
        <ComboBox fx:id="enrollmentCombo" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        
        <Label text="Évaluation (Libelle):" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="1"/>
        <TextField fx:id="libelleField" promptText="Ex: Examen Final" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        
        <Label text="Valeur (0-20):" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="2"/>
        <TextField fx:id="gradeValueField" promptText="Ex: 15.5" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        
        <Label text="Coefficient:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="3"/>
        <Spinner fx:id="coefSpinner" editable="true" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>

</VBox>
