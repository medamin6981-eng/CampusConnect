<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.enspd.campusconnect.controller.GroupeController"
      spacing="20" styleClass="content-pane" style="-fx-background-color: #080808;">

    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher un groupe..." HBox.hgrow="ALWAYS" style="-fx-max-width: 400;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Nouveau Groupe" onAction="#handleAddGroup" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="groupTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode" text="Code" prefWidth="100"/>
            <TableColumn fx:id="colCourse" text="Cours" prefWidth="250"/>
            <TableColumn fx:id="colTeacher" text="Enseignant" prefWidth="200"/>
            <TableColumn fx:id="colRoom" text="Salle" prefWidth="150"/>
            <TableColumn fx:id="colCapacity" text="Capacité" prefWidth="100"/>
            <TableColumn fx:id="colEnrolled" text="Inscrits" prefWidth="100"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>
