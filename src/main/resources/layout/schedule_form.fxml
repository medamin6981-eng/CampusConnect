<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.enspd.campusconnect.controller.ScheduleFormController"
      spacing="15" prefWidth="450" alignment="CENTER"
      style="-fx-background-color: #1A1C1E; -fx-padding: 30;">

    <Text text="Planifier une Séance" style="-fx-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
    
    <GridPane vgap="10" hgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        
        <Label text="Cours:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="0"/>
        <ComboBox fx:id="courseCombo" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        
        <Label text="Groupe:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="1"/>
        <ComboBox fx:id="groupCombo" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        
        <Label text="Enseignant:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="2"/>
        <ComboBox fx:id="teacherCombo" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        
        <Label text="Salle:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="3"/>
        <ComboBox fx:id="roomCombo" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        
        <Label text="Début:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="4"/>
        <HBox spacing="5" GridPane.rowIndex="4" GridPane.columnIndex="1">
            <DatePicker fx:id="datePicker" prefWidth="150"/>
            <TextField fx:id="startTimeField" promptText="HH:mm" prefWidth="80"/>
        </HBox>
        
        <Label text="Fin:" style="-fx-text-fill: #bdc3c7;" GridPane.rowIndex="5"/>
        <TextField fx:id="endTimeField" promptText="HH:mm" maxWidth="Infinity" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>

</VBox>
