<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.enspd.campusconnect.controller.RoomController"
      spacing="20" styleClass="content-pane">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher une salle..." prefWidth="350"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvelle Salle" styleClass="btn-primary" onAction="#handleAddRoom"/>
    </HBox>

    <TableView fx:id="roomTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode" text="Code Salle" prefWidth="150"/>
            <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="120"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="150"/>
        </columns>
    </TableView>

</VBox>
